FLASK_ENV=development
FLASK_DEBUG=1

# Backend
BACKEND_HOST=127.0.0.1
BACKEND_PORT=5000
MAX_UPLOAD_MB=200

# Paths (optional overrides)
UPLOAD_DIR=
WORK_DIR=
MODEL_WEIGHTS_PATH=

# ML
# How many frames to sample from a video (evenly spaced)
VIDEO_MAX_FRAMES=32
MODEL_INPUT_SIZE=224
# Detection threshold: p_fake >= threshold => FAKE, p_fake < threshold => REAL
# Lower values (e.g., 0.3) = more sensitive to detecting fakes (may have more false positives)
# Higher values (e.g., 0.7) = more conservative (may miss some fakes)
DETECTION_THRESHOLD=0.5

# Blockchain (Ethereum testnet)
WEB3_PROVIDER_URL=
CHAIN_ID=
PRIVATE_KEY=
CONTRACT_ADDRESS=

