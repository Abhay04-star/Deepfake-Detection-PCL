FLASK_ENV=development
FLASK_DEBUG=1

# Backend
BACKEND_HOST=127.0.0.1
BACKEND_PORT=5000
MAX_UPLOAD_MB=200

# Paths (optional overrides)
UPLOAD_DIR=
WORK_DIR=
MODEL_WEIGHTS_PATH=

# ML
VIDEO_MAX_FRAMES=32
MODEL_INPUT_SIZE=224
# Lower threshold = more sensitive to detecting fakes
# With the DummyModel fallback, use a lower threshold (0.3-0.4) for better fake detection
DETECTION_THRESHOLD=0.4

# Blockchain (Ethereum testnet) - leave blank if not needed
WEB3_PROVIDER_URL=
CHAIN_ID=
PRIVATE_KEY=
CONTRACT_ADDRESS=
